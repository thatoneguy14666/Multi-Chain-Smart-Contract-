pragma solidity ^0.8.20;

/**
 * @title MultiChainTradingController
 * @dev Main controller for multi-chain trading operations
 * Features: Withdraw, Auto Trading, Stop, Emergency functions
 * Supports: ETH, TRX, SOL, BNB, Polygon networks
 */

import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract MultiChainTradingController is Ownable, ReentrancyGuard {
    using SafeMath for uint256;
    
    // Network IDs
    enum Network {
        ETHEREUM,
        TRON,
        SOLANA,
        BNB,
        POLYGON
    }
    
    // Trading Status
    enum TradingStatus {
        STOPPED,
        RUNNING,
        PAUSED,
        EMERGENCY
    }
    
    // Token addresses for each network
    struct NetworkConfig {
        address nativeToken;
        address usdtAddress;
        address usdcAddress;
        address wethAddress;
        bool isActive;
    }
    
    // User position
    struct UserPosition {
        uint256 totalDeposited;
        uint256 totalWithdrawn;
        uint256 currentBalance;
        uint256 lastTradeTime;
        uint256 profitLoss;
        bool isActive;
    }
    
    // Auto trading parameters
    struct AutoTradeConfig {
        uint256 minProfitThreshold;  // Minimum profit percentage (basis points)
        uint256 maxTradeSize;        // Maximum trade size in USD
        uint256 slippageTolerance;   // Slippage tolerance (basis points)
        uint256 gasLimit;           // Gas limit for trades
        bool useFlashLoans;         // Use flash loans for arbitrage
        bool enabled;               // Auto trading enabled
    }
    
    // State variables
    mapping(Network => NetworkConfig) public networkConfigs;
    mapping(address => UserPosition) public userPositions;
    mapping(Network => mapping(address => uint256)) public networkBalances;
    
    TradingStatus public tradingStatus;
    AutoTradeConfig public autoConfig;
    
    uint256 public totalTVL; // Total Value Locked
    uint256 public totalProfits;
    uint256 public totalTrades;
    uint256 public lastUpdateTime;
    
    address public feeWallet;
    uint256 public platformFee = 25; // 0.25% in basis points
    
    // Events
    event Deposited(address indexed user, Network network, uint256 amount, address token);
    event Withdrawn(address indexed user, Network network, uint256 amount, address token);
    event AutoTradeExecuted(address indexed user, Network network, uint256 profit, uint256 timestamp);
    event TradingStatusChanged(TradingStatus oldStatus, TradingStatus newStatus);
    event EmergencyStopActivated(address indexed caller, string reason);
    event AutoConfigUpdated(AutoTradeConfig newConfig);
    event ProfitDistributed(address indexed user, uint256 amount);
    
    // Modifiers
    modifier onlyWhenRunning() {
        require(tradingStatus == TradingStatus.RUNNING, "Trading is not running");
        _;
    }
    
    modifier onlyWhenNotEmergency() {
        require(tradingStatus != TradingStatus.EMERGENCY, "Emergency stop activated");
        _;
    }
    
    modifier validNetwork(Network network) {
        require(networkConfigs[network].isActive, "Network not configured");
        _;
    }
    
    constructor(address _feeWallet) Ownable(msg.sender) {
        feeWallet = _feeWallet;
        tradingStatus = TradingStatus.STOPPED;
        
        // Initialize auto trading config
        autoConfig = AutoTradeConfig({
            minProfitThreshold: 50,     // 0.5%
            maxTradeSize: 10000 ether,  // $10,000
            slippageTolerance: 100,     // 1%
            gasLimit: 500000,
            useFlashLoans: true,
            enabled: false
        });
    }
    
    // ==================== WITHDRAW TAB FUNCTIONS ====================
    
    /**
     * @dev Withdraw funds from specific network
     */
    function withdrawFromNetwork(
        Network network,
        address token,
        uint256 amount
    ) external nonReentrant onlyWhenNotEmergency validNetwork(network) {
        require(amount > 0, "Amount must be > 0");
        
        UserPosition storage position = userPositions[msg.sender];
        require(position.currentBalance >= amount, "Insufficient balance");
        
        // Update balances
        position.currentBalance = position.currentBalance.sub(amount);
        position.totalWithdrawn = position.totalWithdrawn.add(amount);
        networkBalances[network][token] = networkBalances[network][token].sub(amount);
        totalTVL = totalTVL.sub(amount);
        
        // Transfer tokens
        if (token == address(0)) {
            // Native token
            (bool success, ) = payable(msg.sender).call{value: amount}("");
            require(success, "Transfer failed");
        } else {
            // ERC20 token
            IERC20(token).transfer(msg.sender, amount);
        }
        
        emit Withdrawn(msg.sender, network, amount, token);
    }
    
    /**
     * @dev Withdraw all funds from all networks
     */
    function withdrawAll() external nonReentrant onlyWhenNotEmergency {
        UserPosition storage position = userPositions[msg.sender];
        require(position.currentBalance > 0, "No balance to withdraw");
        
        uint256 totalAmount = position.currentBalance;
        position.currentBalance = 0;
        position.totalWithdrawn = position.totalWithdrawn.add(totalAmount);
        
        // Transfer native token (simplified - would need to track per token)
        (bool success, ) = payable(msg.sender).call{value: totalAmount}("");
        require(success, "Transfer failed");
        
        emit Withdrawn(msg.sender, Network.ETHEREUM, totalAmount, address(0));
    }
    
    /**
     * @dev Emergency withdrawal (bypasses all checks)
     */
    function emergencyWithdraw() external nonReentrant {
        require(tradingStatus == TradingStatus.EMERGENCY, "Not in emergency mode");
        
        UserPosition storage position = userPositions[msg.sender];
        uint256 userBalance = position.currentBalance;
        
        if (userBalance > 0) {
            position.currentBalance = 0;
            position.totalWithdrawn = position.totalWithdrawn.add(userBalance);
            
            (bool success, ) = payable(msg.sender).call{value: userBalance}("");
            require(success, "Emergency transfer failed");
        }
    }
    
    // ==================== AUTO TAB FUNCTIONS ====================
    
    /**
     * @dev Start auto trading
     */
    function startAutoTrading() external onlyOwner onlyWhenRunning {
        require(!autoConfig.enabled, "Auto trading already enabled");
        autoConfig.enabled = true;
        
        emit AutoConfigUpdated(autoConfig);
    }
    
    /**
     * @dev Stop auto trading
     */
    function stopAutoTrading() external onlyOwner {
        require(autoConfig.enabled, "Auto trading not enabled");
        autoConfig.enabled = false;
        
        emit AutoConfigUpdated(autoConfig);
    }
    
    /**
     * @dev Update auto trading configuration
     */
    function updateAutoConfig(
        uint256 minProfitThreshold,
        uint256 maxTradeSize,
        uint256 slippageTolerance,
        uint256 gasLimit,
        bool useFlashLoans
    ) external onlyOwner {
        autoConfig = AutoTradeConfig({
            minProfitThreshold: minProfitThreshold,
            maxTradeSize: maxTradeSize,
            slippageTolerance: slippageTolerance,
            gasLimit: gasLimit,
            useFlashLoans: useFlashLoans,
            enabled: autoConfig.enabled
        });
        
        emit AutoConfigUpdated(autoConfig);
    }
    
    /**
     * @dev Execute auto trade (simplified - would integrate with DEXes)
     */
    function executeAutoTrade(
        Network network,
        address tokenIn,
        address tokenOut,
        uint256 amountIn
    ) external onlyWhenRunning validNetwork(network) returns (uint256 profit) {
        require(autoConfig.enabled, "Auto trading disabled");
        require(amountIn <= autoConfig.maxTradeSize, "Exceeds max trade size");
        
        // Simulate trade execution (would integrate with Uniswap/SushiSwap/etc.)
        uint256 amountOut = simulateTrade(tokenIn, tokenOut, amountIn);
        
        // Calculate profit
        profit = amountOut.sub(amountIn);
        require(profit.mul(10000).div(amountIn) >= autoConfig.minProfitThreshold, "Profit below threshold");
        
        // Update stats
        totalTrades++;
        totalProfits = totalProfits.add(profit);
        
        // Update user position
        UserPosition storage position = userPositions[msg.sender];
        position.profitLoss = position.profitLoss.add(profit);
        position.lastTradeTime = block.timestamp;
        
        // Distribute profits (simplified)
        distributeProfits(msg.sender, profit);
        
        emit AutoTradeExecuted(msg.sender, network, profit, block.timestamp);
        
        return profit;
    }
    
    // ==================== STOP BUTTON FUNCTIONS ====================
    
    /**
     * @dev Start trading
     */
    function startTrading() external onlyOwner {
        require(tradingStatus != TradingStatus.RUNNING, "Already running");
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.RUNNING;
        
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    /**
     * @dev Stop trading
     */
    function stopTrading() external onlyOwner {
        require(tradingStatus == TradingStatus.RUNNING, "Not running");
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.STOPPED;
        
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    /**
     * @dev Pause trading
     */
    function pauseTrading() external onlyOwner {
        require(tradingStatus == TradingStatus.RUNNING, "Not running");
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.PAUSED;
        
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    /**
     * @dev Resume trading
     */
    function resumeTrading() external onlyOwner {
        require(tradingStatus == TradingStatus.PAUSED, "Not paused");
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.RUNNING;
        
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    /**
     * @dev Emergency stop - freezes all operations
     */
    function emergencyStop(string memory reason) external onlyOwner {
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.EMERGENCY;
        
        emit EmergencyStopActivated(msg.sender, reason);
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    /**
     * @dev Recover from emergency stop
     */
    function recoverFromEmergency() external onlyOwner {
        require(tradingStatus == TradingStatus.EMERGENCY, "Not in emergency");
        TradingStatus oldStatus = tradingStatus;
        tradingStatus = TradingStatus.STOPPED;
        
        emit TradingStatusChanged(oldStatus, tradingStatus);
    }
    
    // ==================== NETWORK CONFIGURATION ====================
    
    /**
     * @dev Configure a network
     */
    function configureNetwork(
        Network network,
        address nativeToken,
        address usdtAddress,
        address usdcAddress,
        address wethAddress
    ) external onlyOwner {
        networkConfigs[network] = NetworkConfig({
            nativeToken: nativeToken,
            usdtAddress: usdtAddress,
            usdcAddress: usdcAddress,
            wethAddress: wethAddress,
            isActive: true
        });
    }
    
    /**
     * @dev Disable a network
     */
    function disableNetwork(Network network) external onlyOwner {
        networkConfigs[network].isActive = false;
    }
    
    // ==================== HELPER FUNCTIONS ====================
    
    /**
     * @dev Simulate trade (placeholder - would integrate with price oracles)
     */
    function simulateTrade(
        address tokenIn,
        address tokenOut,
        uint256 amountIn
    ) internal pure returns (uint256) {
        // In reality, this would query Uniswap/SushiSwap pools
        // For demo, return 1% profit
        return amountIn.mul(101).div(100);
    }
    
    /**
     * @dev Distribute profits with platform fee
     */
    function distributeProfits(address user, uint256 profit) internal {
        uint256 fee = profit.mul(platformFee).div(10000);
        uint256 userProfit = profit.sub(fee);
        
        // Update user position
        UserPosition storage position = userPositions[user];
        position.currentBalance = position.currentBalance.add(userProfit);
        
        // Send fee to platform
        if (fee > 0) {
            (bool success, ) = payable(feeWallet).call{value: fee}("");
            require(success, "Fee transfer failed");
        }
        
        emit ProfitDistributed(user, userProfit);
    }
    
    /**
     * @dev Deposit funds (payable function)
     */
    function deposit() external payable nonReentrant onlyWhenNotEmergency {
        require(msg.value > 0, "Must send ETH");
        
        UserPosition storage position = userPositions[msg.sender];
        position.totalDeposited = position.totalDeposited.add(msg.value);
        position.currentBalance = position.currentBalance.add(msg.value);
        position.isActive = true;
        
        networkBalances[Network.ETHEREUM][address(0)] = networkBalances[Network.ETHEREUM][address(0)].add(msg.value);
        totalTVL = totalTVL.add(msg.value);
        
        emit Deposited(msg.sender, Network.ETHEREUM, msg.value, address(0));
    }
    
    /**
     * @dev Deposit ERC20 tokens
     */
    function depositERC20(
        Network network,
        address token,
        uint256 amount
    ) external nonReentrant onlyWhenNotEmergency validNetwork(network) {
        require(amount > 0, "Amount must be > 0");
        
        IERC20(token).transferFrom(msg.sender, address(this), amount);
        
        UserPosition storage position = userPositions[msg.sender];
        position.totalDeposited = position.totalDeposited.add(amount);
        position.currentBalance = position.currentBalance.add(amount);
        position.isActive = true;
        
        networkBalances[network][token] = networkBalances[network][token].add(amount);
        totalTVL = totalTVL.add(amount);
        
        emit Deposited(msg.sender, network, amount, token);
    }
    
    // ==================== VIEW FUNCTIONS ====================
    
    /**
     * @dev Get user position
     */
    function getUserPosition(address user) external view returns (
        uint256 totalDeposited,
        uint256 totalWithdrawn,
        uint256 currentBalance,
        uint256 lastTradeTime,
        uint256 profitLoss,
        bool isActive
    ) {
        UserPosition memory position = userPositions[user];
        return (
            position.totalDeposited,
            position.totalWithdrawn,
            position.currentBalance,
            position.lastTradeTime,
            position.profitLoss,
            position.isActive
        );
    }
    
    /**
     * @dev Get network balance
     */
    function getNetworkBalance(Network network, address token) external view returns (uint256) {
        return networkBalances[network][token];
    }
    
    /**
     * @dev Get contract statistics
     */
    function getStats() external view returns (
        uint256 tvl,
        uint256 profits,
        uint256 trades,
        TradingStatus status,
        bool autoEnabled
    ) {
        return (
            totalTVL,
            totalProfits,
            totalTrades,
            tradingStatus,
            autoConfig.enabled
        );
    }
    
    /**
     * @dev Check if auto trading conditions are met
     */
    function checkAutoTradingConditions() external view returns (bool) {
        return autoConfig.enabled && 
               tradingStatus == TradingStatus.RUNNING &&
               totalTVL > 0;
    }
    
    // Receive function to accept ETH
    receive() external payable {
        deposit();
    }
    
    // Fallback function
    fallback() external payable {
        deposit();
    }
}
